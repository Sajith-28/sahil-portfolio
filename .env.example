# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/atlas → Connect → Connect your application
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/sahil_portfolio?retryWrites=true&w=majority

# Database Name
DB_NAME=sahil_portfolio

# Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters

# Gmail SMTP Configuration for Contact Form Emails
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password (no spaces)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-gmail@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Environment Mode (development or production)
ENVIRONMENT=development
